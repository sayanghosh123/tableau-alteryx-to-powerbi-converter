      <column name="[order_date]" caption="order_date" datatype="date" role="dimension" />
      <column name="[SKU Prefix]" caption="SKU Prefix" datatype="string" role="dimension"><calculation class="tableau" formula="LEFT([sku], 3)" /></column>
      <column name="[Flagged Note]" caption="Flagged Note" datatype="boolean" role="dimension"><calculation class="tableau" formula="CONTAINS([notes], &#x27;urgent&#x27;)" /></column>
