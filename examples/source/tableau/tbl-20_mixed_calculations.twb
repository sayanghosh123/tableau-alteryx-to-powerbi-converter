<?xml version="1.0" encoding="utf-8"?>
<workbook version="2024.1">
  <datasources>
    <datasource name="tbl-20" caption="Mixed calculations">
      <connection class="textscan" />
      <column name="[sales_amount]" caption="sales_amount" datatype="real" role="measure" />
      <column name="[cost_amount]" caption="cost_amount" datatype="real" role="measure" />
      <column name="[profit_amount]" caption="profit_amount" datatype="real" role="measure" />
      <column name="[return_amount]" caption="return_amount" datatype="real" role="measure" />
      <column name="[order_value]" caption="order_value" datatype="real" role="measure" />
      <column name="[profit_margin]" caption="profit_margin" datatype="real" role="measure" />
      <column name="[quantity]" caption="quantity" datatype="integer" role="measure" />
      <column name="[discount_amount]" caption="discount_amount" datatype="real" role="measure" />
      <column name="[refund_amount]" caption="refund_amount" datatype="real" role="measure" />
      <column name="[order_id]" caption="order_id" datatype="string" role="dimension" />
      <column name="[region]" caption="region" datatype="string" role="dimension" />
      <column name="[segment]" caption="segment" datatype="string" role="dimension" />
      <column name="[category]" caption="category" datatype="string" role="dimension" />
      <column name="[channel]" caption="channel" datatype="string" role="dimension" />
      <column name="[sku]" caption="sku" datatype="string" role="dimension" />
      <column name="[notes]" caption="notes" datatype="string" role="dimension" />
      <column name="[status]" caption="status" datatype="string" role="dimension" />
      <column name="[order_date]" caption="order_date" datatype="date" role="dimension" />
      <column name="[Regional Baseline]" caption="Regional Baseline" datatype="real" role="measure"><calculation class="tableau" formula="{ FIXED [region] : SUM([sales_amount]) }" /></column>
      <column name="[Return Rate]" caption="Return Rate" datatype="real" role="measure"><calculation class="tableau" formula="SUM([return_amount]) / SUM([sales_amount])" /></column>
      <column name="[Months Since Order]" caption="Months Since Order" datatype="real" role="measure"><calculation class="tableau" formula="DATEDIFF(&#x27;month&#x27;, [order_date], TODAY())" /></column>
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name="Mixed calculations" />
  </worksheets>
</workbook>
