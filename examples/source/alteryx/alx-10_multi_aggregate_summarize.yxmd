<?xml version="1.0" encoding="utf-8"?>
<AlteryxDocument yxmdVer="2024.1">
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Tool="AlteryxBasePluginsGui.Input.Input" />
      <Properties>
        <Annotation><Name>Read source CSV</Name></Annotation>
      </Properties>
    </Node>
    <Node ToolID="2">
      <GuiSettings Tool="AlteryxBasePluginsGui.Summarize.Summarize" />
      <Properties>
        <Annotation><Name>Summarize region category</Name></Annotation>
        <SummarizeFields>
          <SummarizeField field="region" action="GroupBy" />
          <SummarizeField field="category" action="GroupBy" />
          <SummarizeField field="sales_amount" action="Sum" rename="total_sales" />
          <SummarizeField field="profit_margin" action="Avg" rename="avg_margin" />
          <SummarizeField field="order_id" action="Count" rename="order_count" />
          <SummarizeField field="order_date" action="Max" rename="latest_order" />
        </SummarizeFields>
      </Properties>
    </Node>
    <Node ToolID="3">
      <GuiSettings Tool="AlteryxBasePluginsGui.Output.Output" />
      <Properties>
        <Annotation><Name>Publish draft output</Name></Annotation>
      </Properties>
    </Node>
  </Nodes>
  <Connections>
    <Connection><Origin ToolID="1" Connection="Output" /><Destination ToolID="2" Connection="Input" /></Connection>
    <Connection><Origin ToolID="2" Connection="Output" /><Destination ToolID="3" Connection="Input" /></Connection>
  </Connections>
</AlteryxDocument>
