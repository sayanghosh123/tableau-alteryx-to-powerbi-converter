<?xml version="1.0" encoding="utf-8"?>
<AlteryxDocument yxmdVer="2024.1">
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Tool="AlteryxBasePluginsGui.Input.Input" />
      <Properties>
        <Annotation><Name>Read source CSV</Name></Annotation>
      </Properties>
    </Node>
    <Node ToolID="2">
      <GuiSettings Tool="AlteryxBasePluginsGui.Filter.Filter" />
      <Properties>
        <Annotation><Name>Keep positive sales</Name></Annotation>
        <Expression>[sales_amount] &gt; 0</Expression>
      </Properties>
    </Node>
    <Node ToolID="3">
      <GuiSettings Tool="AlteryxBasePluginsGui.Formula.Formula" />
      <Properties>
        <Annotation><Name>Add profit</Name></Annotation>
        <FormulaFields>
          <FormulaField field="profit_amount" expression="[sales_amount] - [cost_amount]" />
        </FormulaFields>
      </Properties>
    </Node>
    <Node ToolID="4">
      <GuiSettings Tool="AlteryxBasePluginsGui.Summarize.Summarize" />
      <Properties>
        <Annotation><Name>Summarize by region</Name></Annotation>
        <SummarizeFields>
          <SummarizeField field="region" action="GroupBy" />
          <SummarizeField field="sales_amount" action="Sum" rename="total_sales" />
        </SummarizeFields>
      </Properties>
    </Node>
    <Node ToolID="5">
      <GuiSettings Tool="AlteryxBasePluginsGui.Sort.Sort" />
      <Properties>
        <Annotation><Name>Sort total sales</Name></Annotation>
        <SortInfo>
          <Field field="total_sales" order="Descending" />
        </SortInfo>
      </Properties>
    </Node>
    <Node ToolID="6">
      <GuiSettings Tool="AlteryxBasePluginsGui.Output.Output" />
      <Properties>
        <Annotation><Name>Publish draft output</Name></Annotation>
      </Properties>
    </Node>
  </Nodes>
  <Connections>
    <Connection><Origin ToolID="1" Connection="Output" /><Destination ToolID="2" Connection="Input" /></Connection>
    <Connection><Origin ToolID="2" Connection="Output" /><Destination ToolID="3" Connection="Input" /></Connection>
    <Connection><Origin ToolID="3" Connection="Output" /><Destination ToolID="4" Connection="Input" /></Connection>
    <Connection><Origin ToolID="4" Connection="Output" /><Destination ToolID="5" Connection="Input" /></Connection>
    <Connection><Origin ToolID="5" Connection="Output" /><Destination ToolID="6" Connection="Input" /></Connection>
  </Connections>
</AlteryxDocument>
