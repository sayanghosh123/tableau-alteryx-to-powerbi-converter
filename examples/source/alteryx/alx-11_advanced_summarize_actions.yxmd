<?xml version="1.0" encoding="utf-8"?>
<AlteryxDocument yxmdVer="2024.1">
  <Nodes>
    <Node ToolID="1">
      <GuiSettings Tool="AlteryxBasePluginsGui.Input.Input" />
      <Properties>
        <Annotation><Name>Read source CSV</Name></Annotation>
      </Properties>
    </Node>
    <Node ToolID="2">
      <GuiSettings Tool="AlteryxBasePluginsGui.Summarize.Summarize" />
      <Properties>
        <Annotation><Name>Summarize advanced actions</Name></Annotation>
        <SummarizeFields>
          <SummarizeField field="region" action="GroupBy" />
          <SummarizeField field="order_id" action="CountDistinct" rename="distinct_orders" />
          <SummarizeField field="category" action="First" rename="first_category" />
          <SummarizeField field="category" action="Last" rename="last_category" />
          <SummarizeField field="sku" action="Concatenate" rename="sku_list" />
        </SummarizeFields>
      </Properties>
    </Node>
    <Node ToolID="3">
      <GuiSettings Tool="AlteryxBasePluginsGui.Output.Output" />
      <Properties>
        <Annotation><Name>Publish draft output</Name></Annotation>
      </Properties>
    </Node>
  </Nodes>
  <Connections>
    <Connection><Origin ToolID="1" Connection="Output" /><Destination ToolID="2" Connection="Input" /></Connection>
    <Connection><Origin ToolID="2" Connection="Output" /><Destination ToolID="3" Connection="Input" /></Connection>
  </Connections>
</AlteryxDocument>
